<file path="android/build.gradle">
// Top-level build file where you can add configuration options common to all sub-projects/modules.

buildscript {
    repositories {
        google()
        mavenCentral()
    }
    dependencies {
        classpath 'com.android.tools.build:gradle:8.2.2'
        classpath 'com.google.gms:google-services:4.4.0'
    }
}

apply from: "variables.gradle"

allprojects {
    repositories {
        google()
        mavenCentral()
    }

    configurations.all {
        resolutionStrategy {
            // Sube la prioridad de la versión 1.78.1 para evitar el bytecode de Java 21 en la 1.79
            eachDependency { details ->
                if (details.requested.group == 'org.bouncycastle' && details.requested.name.contains('jdk18on')) {
                    details.useVersion '1.78.1'
                }
            }
        }
    }
}

task clean(type: Delete) {
    delete rootProject.buildDir
}
