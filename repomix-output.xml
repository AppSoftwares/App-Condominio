        // Simple micro-interaction for calendar days
        document.querySelectorAll('.calendar-grid div:not(.font-label-sm)').forEach(day => {
            day.addEventListener('click', function() {
                if(this.textContent.trim() !== "" && !this.classList.contains('text-outline')) {
                    document.querySelector('.bg-primary.text-on-primary')?.classList.remove('bg-primary', 'text-on-primary', 'font-bold');
                    this.classList.add('bg-primary', 'text-on-primary', 'font-bold');
                }
            });
        });

        // Reserve buttons interaction
        document.querySelectorAll('button').forEach(btn => {
            if(btn.textContent.includes('Reservar') && !btn.classList.contains('cursor-not-allowed') && btn.closest('main')) {
                btn.addEventListener('click', () => {
                    const areaCard = btn.closest('.group');
                    const areaName = areaCard.querySelector('h3').textContent;
                    const timeSelected = areaCard.querySelector('select').value;
                    alert(`Confirmando reservación para ${areaName} en el horario: ${timeSelected}`);
                });
            }
        });
    </script>
