<script>
        const conjuntosPorEtapa = {
            "I": ["La Pradera", "Los Jarales", "El Roble"],
            "II": ["Punta de Piedra", "Las Isletas", "Punta Mangle"],
            "III": ["Altos del Mirador", "Lomas del Sol"],
            "IV": ["Residencias Lagunita", "The Collection"]
        };

        const etapaSelect = document.getElementById('etapa');
        const conjuntoSelect = document.getElementById('conjunto');
        const password = document.getElementById('password');
        const confirmPassword = document.getElementById('confirm_password');
        const passwordError = document.getElementById('passwordError');
        const houseNumber = document.getElementById('house_number');
        const houseFormatError = document.getElementById('houseFormatError');
        const form = document.getElementById('registrationForm');

        // Stage -> Conjunto dependency logic
        etapaSelect.addEventListener('change', function() {
            const etapa = this.value;
            conjuntoSelect.disabled = false;
            conjuntoSelect.innerHTML = '<option value="" disabled selected>Seleccione conjunto</option>';
            
            conjuntosPorEtapa[etapa].forEach(conjunto => {
                const option = document.createElement('option');
                option.value = conjunto;
                option.textContent = conjunto;
                conjuntoSelect.appendChild(option);
            });
        });

        // Form Validation Logic
        form.addEventListener('submit', function(e) {
            let isValid = true;

            // Password Check
            if (password.value !== confirmPassword.value) {
                passwordError.classList.remove('hidden');
                confirmPassword.classList.add('border-error');
                isValid = false;
            } else {
                passwordError.classList.add('hidden');
                confirmPassword.classList.remove('border-error');
            }

            // House Format Check (Simplified Regex for XX-XX)
            const houseRegex = /^\d{1,3}-\d{1,3}$/;
            if (!houseRegex.test(houseNumber.value)) {
                houseFormatError.classList.remove('hidden');
                houseNumber.classList.add('border-error');
                isValid = false;
            } else {
                houseFormatError.classList.add('hidden');
                houseNumber.classList.remove('border-error');
            }

            if (!isValid) {
                e.preventDefault();
                // Simple vibration-like feedback for desktop/mobile
                form.classList.add('animate-shake');
                setTimeout(() => form.classList.remove('animate-shake'), 400);
            } else {
                e.preventDefault();
                alert('¡Registro exitoso! Bienvenido a Caminos de la Lagunita.');
            }
        });

        // Real-time password check feedback
        confirmPassword.addEventListener('input', function() {
            if (this.value === password.value) {
                passwordError.classList.add('hidden');
                this.classList.remove('border-error');
            }
        });
    </script>
<style>
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-4px); }
            75% { transform: translateX(4px); }
        }
        .animate-shake {
            animation: shake 0.2s ease-in-out 0s 2;
        }
        .border-error {
            border-color: #ba1a1a !vehemently;
        }
    </style>
</body></html>
