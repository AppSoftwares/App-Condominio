<file path=".github/workflows/ios-build.yml">
name: iOS Build IPA

on:
  workflow_dispatch:
    inputs:
      build_id:
        description: 'Nombre del archivo base'
        required: true
        default: 'CaminosApp'

jobs:
  build:
    runs-on: macos-14
    permissions:
      contents: write

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Node 22
        uses: actions/setup-node@v4
        with:
          node-version: '22'

      - name: Setup Java 21
        uses: actions/setup-java@v4
        with:
          distribution: 'zulu'
          java-version: '21'

      - name: Check Java Version
        run: java -version

      - name: Install dependencies
        run: npm install --include=optional

      - name: Fix Rollup for MacOS
        run: npm install @rollup/rollup-darwin-arm64 --no-save

      - name: Create .env file
        run: |
          if [ -f .env.example ]; then
            cp .env.example .env
          fi

      - name: Build Web Project
        run: npm run build:ci

      - name: Generate Assets
        run: |
          npx @capacitor/assets generate --iconBackgroundColor '#0f5551' --iconBackgroundColorDark '#0f5551'
          find android/app/src/main/res -name "*.webp" -delete || true
          rm -rf ios/App/CapApp-SPM

      - name: Capacitor Sync
        run: npx cap sync

      - name: Install CocoaPods Dependencies
        run: |
          cd ios/App
          pod deintegrate || true
          pod install

      - name: Verify Podfile.lock
        run: |
          if [ -f "ios/App/Podfile.lock" ]; then
            echo "Podfile.lock exists."
            ls -l ios/App/Podfile.lock
          else
            echo "Error: Podfile.lock not found!"
            exit 1
          fi

      - name: Build Android App (Release)
        env:
          GRADLE_OPTS: -Dorg.gradle.jvmargs="-Xmx4096m -XX:MaxMetaspaceSize=1024m"
        run: |
          cd android
          chmod +x gradlew
          ./gradlew assembleRelease --no-daemon --stacktrace --info

      - name: Prepare Android Artifact
        run: |
          mv android/app/build/outputs/apk/release/CaminosApp-v2.2.8.apk "CaminosApp v2.2.8.apk"

      - name: Build iOS App (Unsigned)
        env:
          PODS_ROOT: ${{ github.workspace }}/ios/App/Pods
          PODS_PODFILE_DIR_PATH: ${{ github.workspace }}/ios/App
        run: |
          cd ios/App
          xcodebuild -resolvePackageDependencies -workspace App.xcworkspace -scheme App || true
          
          xcodebuild -workspace App.xcworkspace \
                    -scheme App \
                    -configuration Debug \
                    -destination 'generic/platform=iOS' \
                    -sdk iphoneos \
                    -derivedDataPath "${GITHUB_WORKSPACE}/DerivedData" \
                    CODE_SIGNING_ALLOWED=NO \
                    CODE_SIGNING_REQUIRED=NO \
                    CODE_SIGN_IDENTITY="" \
                    COMPILER_INDEX_STORE_ENABLE=NO \
                    ENABLE_USER_SCRIPT_SANDBOXING=NO \
                    ONLY_ACTIVE_ARCH=NO \
                    build

      - name: Create IPA for Sideloadly
        run: |
          APP_PATH=$(find "${GITHUB_WORKSPACE}/DerivedData/Build/Products/Debug-iphoneos" -name "*.app" -type d | head -1)
          if [ -z "$APP_PATH" ]; then
            echo "Error: No se encontró el binario .app"
            exit 1
          fi
          mkdir -p Payload
          cp -R "$APP_PATH" Payload/
          zip -rq "CaminosApp v2.2.8.ipa" Payload

      - name: Create Release
        uses: softprops/action-gh-release@v2
        with:
          tag_name: v2.2.8
          name: "CaminosApp v2.2.8"
          files: |
            *.ipa
            *.apk
          body: |
            Actualización CaminosApp v2.2.8 (Lanzamiento Piloto)
            - Profesionalización: Eliminación total de simuladores. Votaciones, Anuncios e Incidentes ahora funcionan con el backend real.
            - Hardware Nativo: Integración de escaneo de QR profesional (MLKit) y biometría avanzada (FaceID/Huella).
            - Seguridad: Activación de RLS en Incidentes, protección MFA (2FA) obligatoria y endurecimiento de políticas CORS.
            - Auditoría: Nueva tabla de logs de auditoría para rastrear cambios sensibles en la base de datos.
            - UX: Formateo automático de número de casa (XX-XX) y nuevos estados vacíos en todas las listas principales.
