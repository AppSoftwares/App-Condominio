# Configuración de Supabase (Público)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Entorno
NODE_ENV=development

# Configuración de Monitoreo (Opcional)
VITE_SENTRY_DSN=your-sentry-dsn

# Backend Config
SECRET_KEY=una_llave_muy_segura_aqui
DATABASE_URL=postgresql://user:password@localhost/dbname

# Initial Passwords
INITIAL_ADMIN_PASSWORD=JESUS.ADMIN.HUERTA
INITIAL_CARLOS_PASSWORD=CARLOS.HUERTAS.123
INITIAL_JESUS_PASSWORD=JESUS.HUERTAS.123
INITIAL_VIGILANTE_PASSWORD=JESUS.VIGILANTE.HUERTA
