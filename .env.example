# Example .env file for CaminosApp
# Copy this file to .env (backend) and to .env.local (frontend) as needed.

# ----------------------
# Database (backend)
# For development you can use SQLite: sqlite:///./database.db
DATABASE_URL=sqlite:///./database.db

# ----------------------
# Secrets (backend)
# Use a long random value in production. Example: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change_me_to_a_secure_random_value

# Initial seeded passwords (only used if DB is empty at startup)
INITIAL_ADMIN_PASSWORD=ChangeMeAdminPwd
INITIAL_CARLOS_PASSWORD=
INITIAL_JESUS_PASSWORD=
INITIAL_VIGILANTE_PASSWORD=

# ----------------------
# Supabase (frontend public keys)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ----------------------
# Optional: error monitoring and update URL
VITE_SENTRY_DSN=
VITE_UPDATE_JSON_URL=

# NODE / BUILD
NODE_ENV=production
PORT=5173
